# kotoha の環境変数サンプル。
# このファイルを .env にコピーして値を埋める(.env は .gitignore 済みで公開されない)。
#   cp .env.example .env
#
# 長期記憶の昇格(短期記憶 -> 長期記憶の統合)に使う Gemini API キー。
# 未設定でも会話・短期記憶までは動作し、昇格のみ無効になる。
# 取得: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# 天気の API 検索(OpenWeather)に使うキー。未設定なら天気検索は無効。
# 取得: https://openweathermap.org/api
OPENWEATHER_API_KEY=

# 天気の既定地点(発話に都市名が無いとき)。OpenWeather の "都市,国コード" 形式。
# 例: Tokyo,JP / Osaka,JP。未設定なら Tokyo。
OPENWEATHER_CITY=

# 毎ターンの「現在の状況」プロンプトに入れる現在地表示。未設定なら OPENWEATHER_CITY を使う。
# 例: 大阪 / Osaka,JP
KOTOHA_PLACE=

# 画面知覚(任意・既定OFF)。画面を一定間隔で VLM 要約し会話へ織り込む。
# 有効化は true / 1 / yes / on のいずれか。単一GPU(RTX 4080)では会話と同じ
# qwen3.5:4b(vision 対応)を使い回す既定で、追加 VRAM・モデルスワップを避ける。
SCREEN_PERCEPTION_ENABLED=
# 知覚VLM のモデル。空なら既定(qwen3.5:4b)。専用VLMを使うなら例: qwen3-vl:4b。
VLM_PERCEPTION_MODEL=
# 画面キャプチャ方式。空なら mss。ゲーム画面も取るなら dxcam(Windows)。
SCREEN_CAPTURE_BACKEND=

# 非リアルタイム推論(知覚VLM・記憶圧縮・関係性分析)を別バックエンドへ向ける。
# 例: Radeon VII の Vulkan サーバ。空ならローカルの Ollama を使う。
VLM_PERCEPTION_URL=
AUX_LLM_URL=

# 会話 LLM の接続先を上書きする(任意)。空なら http://localhost:11434。
OLLAMA_URL=

# --- デスクトップ操作グラウンディング (既定OFF。実作動は3つの明示設定が必要) ---
# OPERATION_ENABLED=true
# OPERATION_DRY_RUN=false                 # arm: 可視化でなく実作動
# OPERATION_APP_ALLOWLIST=chrome.exe,code.exe   # 空=全拒否
# GROUNDING_URL=http://localhost:11436    # 空なら VLM_PERCEPTION_URL→OLLAMA_URL
# GROUNDING_MODEL=holo2-8b
